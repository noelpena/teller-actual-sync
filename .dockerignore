# Dependencies (will be installed in container)
node_modules
npm-debug.log
yarn-error.log

# Git and CI/CD
.git
.gitignore
.github

# Environment files (contain credentials)
.env
.env.*
.env.local
.env.*.local
.env.hide
.env.example

# Certificates (security-sensitive)
certs
certs/*.pem

# Configuration examples (not needed in image)
config.json.example

# Build artifacts
dist
build

# Logs
logs
*.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode
.idea
*.swp
*.swo

# Runtime data (created by application)
actual-data
transaction-data
config/config.json

# Docker files (not needed in image)
Dockerfile
docker-compose.yml
.dockerignore

# Documentation (saves image size)
README.md
LICENSE
