# ============================================
# TELLER CONFIGURATION
# ============================================

# Your Teller Application ID (required)
APP_ID=your_teller_app_id_here

# Environment: sandbox, development, or production
# - sandbox: No certificates required (testing only)
# - development/production: Requires mTLS certificates
ENV=sandbox

# Access Token (obtained after user connects via Teller Connect)
TELLER_ACCESS_TOKEN=your_teller_access_token_here

# Teller Account ID (the specific bank account to sync)
TELLER_ACCOUNT_ID=your_teller_account_id_here

# ============================================
# mTLS CERTIFICATES (Required for development/production)
# ============================================
# Only needed when ENV=development or ENV=production
# Leave commented out for sandbox testing

# Absolute paths to your Teller-issued certificate files:
# CERT=/app/certs/certificate.pem
# CERT_KEY=/app/certs/private_key.pem

# For Docker, mount your certs and use paths like:
# CERT=/app/certs/certificate.pem
# CERT_KEY=/app/certs/private_key.pem

# ============================================
# ACTUAL BUDGET CONFIGURATION
# ============================================

# Server URL (your self-hosted Actual Budget server)
ACTUAL_SERVER_URL=http://your-actual-server:5006

# Password for your Actual Budget server
ACTUAL_PASSWORD=your_actual_password_here

# Budget Sync ID (Settings → Show Advanced Settings → Sync ID)
# This identifies which budget file to use
ACTUAL_SYNC_ID=your_budget_sync_id_here

# Account ID (the specific account within your budget to import transactions to)
# Find this in the URL when viewing an account: /accounts/{ACCOUNT_ID}
# Example: Open "Chase Checking" → URL shows /accounts/d34d071e-6adf-425e-940b-d1c53e6de7dc
ACTUAL_ACCOUNT_ID=your_actual_account_id_here

# Sync Configuration
DAYS_TO_SYNC=7
CRON_SCHEDULE=0 2 * * *

# Optional: SSL Certificates (for production Teller environment)
# CERT=/path/to/cert.pem
# CERT_KEY=/path/to/key.pem

# Timezone (adjust to your location)
TZ=America/New_York